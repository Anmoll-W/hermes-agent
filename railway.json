{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "/usr/bin/tini -g -- /opt/hermes/docker/entrypoint.sh gateway run --replace --accept-hooks",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 100,
    "numReplicas": 1,
    "region": "ap-southeast1"
  }
}
